# WordPress REST API base. Default is the same-origin proxy (/wp-api/wp/v2),
# which Vite (dev) and vercel.json (production) rewrite to
# https://stearnsmedia.com/index.php?rest_route=/wp/v2 — required because the
# live site sends no CORS headers. Only override if the proxy setup changes.
VITE_WP_API_BASE=/wp-api/wp/v2

# FormSubmit (https://formsubmit.co) delivery address for the contact form.
# The FIRST submission triggers an activation email to this inbox — the client
# must click the activation link once before messages are delivered.
VITE_FORMSUBMIT_TARGET=info@stearnsmedia.com

# HubSpot CRM lead capture (optional — skipped when empty).
# Portal ID: HubSpot Settings → Account Setup → Account Defaults.
# Form GUID: create a form in HubSpot Marketing → Forms, copy the ID from its
# embed code or URL.
VITE_HUBSPOT_PORTAL_ID=
VITE_HUBSPOT_FORM_GUID=

# Cal.com booking link rendered in the Contact section.
# The client must create a "discovery-call" event type in their Cal.com
# account (username "stearnsmedia") and connect a calendar before the embed
# accepts bookings. Until then the embed shows a 404 message.
VITE_CAL_LINK=stearnsmedia/discovery-call
